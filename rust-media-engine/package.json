{
  "name": "rust-media-engine",
  "version": "0.1.0",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "rust-media-engine",
    "targets": [
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "prebuild": "node -e \"try{require('fs').renameSync('rust-media-engine.win32-x64-msvc.node', 'rust-media-engine.win32-x64-msvc.old.node')}catch(e){}\"",
    "build": "npm run prebuild && napi build --platform --release",
    "build:cuda": "npm run prebuild && napi build --platform --release --features cuda",
    "build:metal": "npm run prebuild && napi build --platform --release --features metal",
    "build:debug": "npm run prebuild && napi build --platform"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}
