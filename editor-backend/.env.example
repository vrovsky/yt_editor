# ─── Server ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────
# Comma-separated allowlist of browser origins. NEVER use "*" in production.
CORS_ORIGIN=http://localhost:3000

# ─── Authentication (Clerk) ──────────────────────────────────────────
# Without CLERK_SECRET_KEY the API runs UNAUTHENTICATED (demo mode only).
# Set REQUIRE_AUTH=true in production to refuse to boot without auth.
CLERK_SECRET_KEY=
REQUIRE_AUTH=false

# ─── AI (optional — deterministic mode works without it) ─────────────
# Leave OPENAI_API_KEY empty to disable the token-spending LLM path.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Persistence & retention ─────────────────────────────────────────
DATA_DIR=./data
# Hours to keep uploaded videos / exports before auto-deletion (privacy).
RETENTION_HOURS=24
# Max file size (MB) read into memory for analysis.
ANALYZE_MAX_MB=4096
